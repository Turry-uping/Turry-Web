{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "启动个人网站本地预览",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "http.server",
        "5500",
        "--bind",
        "127.0.0.1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "打开本地预览地址",
      "type": "shell",
      "command": "start",
      "args": [
        "http://127.0.0.1:5500/index.html"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never"
      }
    }
  ]
}
